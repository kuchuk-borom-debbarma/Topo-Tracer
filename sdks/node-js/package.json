{
  "name": "@topo-tracer/node-sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for Topo-Tracer graph-based telemetry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun test",
    "bench": "bun run ./tests/performance.bench.ts",
    "build": "rm -rf ./dist && tsc -p ./tsconfig.json",
    "demo:e2e": "bun run ./examples/end-to-end-demo.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "tracing",
    "telemetry",
    "graph",
    "topo-tracer",
    "node-sdk"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "latest",
    "mitata": "^1.0.34",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
