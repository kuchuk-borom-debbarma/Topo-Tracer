{
  "name": "carno.js",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "seed": "bun run scripts/generate-mock.ts",
    "seed:large": "bun run scripts/generate-mock.ts --large",
    "check": "bun build src/index.ts --target bun --outdir /private/tmp/topo-tracer-build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@carno.js/core": "^1.5.0",
    "@clickhouse/client": "^1.18.5"
  }
}
